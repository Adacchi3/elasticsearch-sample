<% content_for :title, "記事検索" %>

<div class="min-h-screen bg-gray-50 py-10 px-4">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-8">記事全文検索</h1>

    <%= form_with url: search_articles_path, method: :get, local: true, class: "mb-8" do |f| %>
      <div class="flex gap-2">
        <%= f.text_field :q,
            value: @keyword,
            placeholder: "キーワードを入力...",
            class: "flex-1 border border-gray-300 rounded-lg px-4 py-2 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        <%= f.submit "検索",
            class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2 rounded-lg cursor-pointer transition-colors" %>
      </div>
    <% end %>

    <% if @error_message.present? %>
      <div class="bg-red-50 border border-red-300 text-red-700 rounded-lg px-4 py-3 mb-6">
        <%= @error_message %>
      </div>
    <% end %>

    <% if @keyword.present? %>
      <p class="text-gray-500 text-sm mb-4">
        「<span class="font-semibold text-gray-700"><%= @keyword %></span>」の検索結果:
        <span class="font-semibold"><%= @total_count %></span> 件
      </p>

      <% if @results.empty? %>
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg">該当する記事が見つかりませんでした。</p>
          <p class="text-sm mt-2">別のキーワードでお試しください。</p>
        </div>
      <% else %>
        <div class="space-y-4">
          <% @results.each do |article| %>
            <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm hover:shadow-md transition-shadow">
              <h2 class="text-xl font-semibold text-blue-700 mb-2"><%= article[:title] %></h2>
              <p class="text-gray-600 text-sm mb-3 leading-relaxed"><%= article[:body_excerpt] %></p>
              <p class="text-gray-400 text-xs">投稿日時: <%= article[:published_at] %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
